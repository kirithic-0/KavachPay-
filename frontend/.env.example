# KavachPay Frontend Environment Variables
# Copy this to .env and fill in your actual values

# Backend API URL (Flask server)
REACT_APP_API_URL=http://localhost:5000

# Mock platform API URL (employee verification mock server)
REACT_APP_MOCK_API_URL=http://localhost:5001

# Gemini API Key (for AI-powered chatbot — leave empty to use rule-based fallback)
REACT_APP_GEMINI_KEY=
